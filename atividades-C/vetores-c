#include <stdio.h>
#define MIN_QTD 3
#define MAX_QTD 50

int tamanhoVetor();
void inserir(int v[], int *n, int valor);
int busca(int v[], int n, int valor);
void remover(int v[], int *n, int valor);

int main(){
    int cap = tamanhoVetor();
    int v[MAX_QTD];
    int n = 0;

    
    for(int i = 0; i < cap; i+=1){
        int valor;
        printf("Valor %d: ", i + 1);
        scanf("%d", &valor);
        inserir(v, &n, valor);
    }

    int menu;

    do{
        printf("\n1 imprimir\n2 buscar\n3 remover\n4 inserir\n0 sair\n");
        scanf("%d", &menu);

        if(menu == 1){
            for(int i = 0; i < n; i+=1){
                printf("%d ", v[i]);
            }
            printf("\n");
        }

        else if(menu == 2){
            int valor;
            printf("buscar: ");
            scanf("%d", &valor);

            int posicao = busca(v, n, valor);

            if(posicao == -1)
                printf("Nao se encontra na lista\n");
            else
                printf("Posicao: %d\n", posicao + 1);
        }

        else if(menu == 3){
            int valor;
            printf("remover: ");
            scanf("%d", &valor);

            remover(v, &n, valor);
        }

        else if(menu == 4){
            if(n == cap){
                printf("Vetor cheio\n");
            } else {
                int valor;
                printf("inserir: ");
                scanf("%d", &valor);
                inserir(v, &n, valor);
            }
        }

    }while(menu != 0);

    return 0;
}

int tamanhoVetor(){
    int t;

    do{
        printf("Tamanho do vetor (%d-%d): ", MIN_QTD, MAX_QTD);
        scanf("%d", &t);
    }while(t < MIN_QTD || t > MAX_QTD);

    return t;
}

void inserir(int v[], int *n, int valor){
    int i = *n - 1;

    while(i >= 0 && v[i] > valor){
        v[i+1] = v[i];
        i--;
    }

    v[i+1] = valor;
    (*n)+=1;
}

int busca(int v[], int n, int valor){
    int inicio = 0, fim = n-1;

    while(inicio <= fim){
        int meio = (inicio + fim)/2;

        if(v[meio] == valor) return meio;

        if(valor < v[meio])
            fim = meio-1;
        else
            inicio = meio+1;
    }

    return -1;
}

void remover(int v[], int *n, int valor){
    int posicao = busca(v, *n, valor);

    if(posicao == -1) return;

    for(int i = posicao; i < *n - 1; i+=1){
        v[i] = v[i+1];
    }

    (*n)--;
}
