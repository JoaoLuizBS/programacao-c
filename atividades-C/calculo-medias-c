#include <stdio.h>

int main() {
    double nota1[30], nota2[30], media[30];
    double mediaTurma = 0;
    int i;
    for(i = 0; i < 30; i+=1) {
        printf("Aluno %d\n", i + 1);

        printf("Digite a primeira nota: ");
        scanf("%lf", &nota1[i]);

        printf("Digite a segunda nota: ");
        scanf("%lf", &nota2[i]);
        media[i] = (nota1[i]*2 + nota2[i]*3) / 5;

        mediaTurma += media[i];
    }
    mediaTurma = mediaTurma / 30;
    printf("\nMedia da turma: %.2lf\n", mediaTurma);
    printf("\nAlunos acima da media da turma:\n");
    for(i = 0; i < 30; i+=1) {
        if(media[i] > mediaTurma) {
            printf("Aluno %d -> Media: %.2lf\n",
                   i + 1, media[i]);
        }
    }
    return 0;
}
