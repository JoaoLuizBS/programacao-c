#include <stdio.h>
#include <string.h>
#define TAM 100

struct Categoria{
    int codigo;
    char nome[50];
};

struct Produto{
    int codigo;
    char titulo[100];
    char descricao[256];
    int categoria;
    int preco;
};

void cadastrarCategoria(struct Categoria v[], int *qtd);
void imprimirCategorias(struct Categoria v[], int qtd);
void imprimirProdutos(struct Produto vp[], int qtdProdutos,struct Categoria vc[], int qtdCategorias);
void selectionSortPorDescricao(struct Produto v[], int qtd);
int buscaBinariaPorDescricao(struct Produto v[], int qtd, char *x);

int main(){

    struct Categoria categorias[TAM];
    struct Produto produtos[TAM];

    int qtdCategorias = 0;
    int qtdProdutos = 0;

    char busca[256];

    cadastrarCategoria(categorias, &qtdCategorias);
    cadastrarCategoria(categorias, &qtdCategorias);
    cadastrarCategoria(categorias, &qtdCategorias);

    // Como não tem um cadastrar produtos na prova, criei três exemplos de teste //
    produtos[0].codigo = 1;
    strcpy(produtos[0].titulo, "maca");
    strcpy(produtos[0].descricao, "deliciosa");
    produtos[0].categoria = categorias[0].codigo;
    produtos[0].preco = 500;

    produtos[1].codigo = 2;
    strcpy(produtos[1].titulo, "arroz");
    strcpy(produtos[1].descricao, "soltinho");
    produtos[1].categoria = categorias[1].codigo;
    produtos[1].preco = 1000;

    produtos[2].codigo = 3;
    strcpy(produtos[2].titulo, "carne");
    strcpy(produtos[2].descricao, "bife");
    produtos[2].categoria = categorias[2].codigo;
    produtos[2].preco = 1500;

    qtdProdutos = 3;

    printf("\nCATEGORIAS:\n");
    imprimirCategorias(categorias, qtdCategorias);

    printf("\nPRODUTOS:\n");
    imprimirProdutos(produtos, qtdProdutos, categorias, qtdCategorias);

    selectionSortPorDescricao(produtos, qtdProdutos);

    printf("\nDigite a descricao para buscar: ");
    fgets(busca, 256, stdin);

    busca[strcspn(busca, "\n")] = '\0';

    int pos = buscaBinariaPorDescricao(produtos, qtdProdutos, busca);

    if (pos != -1) {
        printf("Produto encontrado: %s\n", produtos[pos].titulo);
    }
    else {
        printf("Produto nao encontrado.\n");
    }

    return 0;
}



void cadastrarCategoria(struct Categoria v[], int *qtd) {
    if (*qtd >= TAM) {
        printf("Espaco lotado.\n");
        return;
    }

    printf("Digite o codigo da categoria: ");
    scanf("%d", &v[*qtd].codigo);
    getchar(); 

    printf("Digite o nome da categoria: ");
    fgets(v[*qtd].nome, 50, stdin);

    (*qtd)++;
}

void imprimirCategorias(struct Categoria v[], int qtd) {
    for (int i = 0; i < qtd; i++) {
        printf("Codigo: %d\n", v[i].codigo);
        printf("Nome: %s\n", v[i].nome);
        printf("---------------------\n");
    }
}

void imprimirProdutos(struct Produto vp[], int qtdProdutos,struct Categoria vc[], int qtdCategorias) {
    char nomeCategoria[50];
    for (int i = 0; i < qtdProdutos; i++) {
        for (int j = 0; j < qtdCategorias; j++) {
            if (vp[i].categoria == vc[j].codigo) {
                strcpy(nomeCategoria, vc[j].nome);
            }
        }
        printf("Codigo: %d\n", vp[i].codigo);
        printf("Titulo: %s\n", vp[i].titulo);
        printf("Descricao: %s\n", vp[i].descricao);
        printf("Categoria: %s\n", nomeCategoria);
        printf("Preco: R$ %.2f\n", vp[i].preco / 100.0);
        printf("--------------------------\n");
    }
}

void selectionSortPorDescricao(struct Produto v[], int qtd) {

    int menor;
    struct Produto aux;
    for (int i = 0; i < qtd - 1; i++) {
        menor = i;
        for (int j = i + 1; j < qtd; j++) {
            if (strcmp(v[j].descricao, v[menor].descricao) < 0) {
                menor = j;
            }
        }
        aux = v[i];
        v[i] = v[menor];
        v[menor] = aux;
    }
}

int buscaBinariaPorDescricao(struct Produto v[], int qtd, char *x) {

    int inicio = 0;
    int fim = qtd - 1;
    int meio;

    while (inicio <= fim) {

        meio = (inicio + fim) / 2;

        if (strcmp(v[meio].descricao, x) == 0) {
            return meio; 
        }
        else if (strcmp(v[meio].descricao, x) < 0) {
            inicio = meio + 1;
        }
        else {
            fim = meio - 1;
        }
    }
    return -1;
}
